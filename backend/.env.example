# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# Riot API key. OPTIONAL and unused by the core product: winrates come from the
# first-party ingest pipeline, and the augment/champion static-data helpers are
# keyless. Leave unset unless a future feature needs a direct Riot call. Startup
# does not require it.
# RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SQLite database file for ingested matches and aggregation.
# Use ":memory:" for ephemeral/test runs. Defaults to backend/mayhem.db.
DATABASE_PATH=mayhem.db

# Queue ID used to validate "ARAM Mayhem" ingest and shared with the collector.
# 2400 = ARAM Mayhem. 450 = standard ARAM (no augment data), do not use it.
# Override only if Riot changes the Mayhem queue id.
ARAM_QUEUE_ID=2400

# Pins the Community Dragon augment static-data version.
CDRAGON_VERSION=latest

# Pins the Data Dragon version used for champion icons.
DDRAGON_VERSION=14.10.1

# Flask
FLASK_DEBUG=1

# Comma-separated origins allowed by CORS (the Vite dev server by default).
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
